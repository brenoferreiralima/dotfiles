### WINDOW ###
# gtk-titlebar = false
window-padding-x = 12
window-padding-y = 12
window-height = 32
window-width = 110


### THEME ###
theme = Gnome Monokai
# theme = Adwaita Dark
# background = #222226
# background = #2E2E32
# background = #1D1D20
bold-is-bright = true


### FONT ###
font-family = FiraCode Nerd Font
font-size = 11


### SYSTEM ###
shell-integration-features = no-cursor, ssh-env
cursor-style = underline
scrollbar = system

